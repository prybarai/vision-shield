{
 "compilerOptions": {
 "target": "ES2020",
 "lib": ["dom", "dom.iterable", "esnext"],
 "allowJs": true,
 "skipLibCheck": true,
 "strict": true,
 "noEmit": true,
 "esModuleInterop": true,
 "module": "esnext",
 "moduleResolution": "bundler",
 "resolveJsonModule": true,
 "isolatedModules": true,
 "jsx": "preserve",
 "incremental": true,
 "plugins": [{ "name": "next" }],
 "baseUrl": ".",
 "paths": {
 "@/*": ["./*"]
 }
 },
 "include": [
  "next-env.d.ts",
  "app/**/*.ts",
  "app/**/*.tsx",
  "components/*.tsx",
  "components/ui/**/*.tsx",
  "components/vision/**/*.tsx",
  "lib/**/*.ts",
  "lib/**/*.tsx",
  "types/**/*.ts",
  ".next/types/**/*.ts"
 ],
 "exclude": [
  "node_modules",
  "legacy_disabled/**/*",
  "components/layout/**/*",
  "components/providers/**/*",
  "components/shield/**/*",
  "components/vision/MaterialsCartPolished.tsx",
  "components/vision/NailiOrchestrator.tsx",
  "components/vision/ProjectAutoSaver.tsx",
  "components/vision/VisionRevealPolished.tsx"
 ]
}
